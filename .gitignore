.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.mono/

# Mono/Rider/Resharper/IntelliJ
.idea/
*.sln.imap
*.csproj.user
*.resharper.user
_ReSharper*/

# VS Code
.vscode/
